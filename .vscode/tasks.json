{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Duckle: start Tauri dev with debug logs",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\debug.ps1"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "tauri: frontend dev server",
      "type": "shell",
      "command": "npm --prefix frontend run dev",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": ".*" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "vite v.*ready in",
          "endsPattern": "Local:.*http://localhost:5173"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "duckle-vite",
        "clear": false
      }
    },
    {
      "label": "tauri: build desktop debug",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "cargo build -p duckle-runner --bins; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; cargo build -p duckle-desktop; exit $LASTEXITCODE"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": "$rustc",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "duckle-build",
        "clear": true
      }
    },
    {
      "label": "Duckle: prepare F5 debug",
      "dependsOn": [
        "tauri: build desktop debug",
        "tauri: frontend dev server"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "frontend: export MCP component catalog",
      "detail": "Regenerates crates/duckle-mcp/catalog.json from the frontend palette and manifests. Run after changing a component's id, fields, ports, label, summary, or availability so MCP clients receive the authoritative schema.",
      "type": "shell",
      "command": "npm --prefix frontend run export-catalog",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    }
  ]
}
