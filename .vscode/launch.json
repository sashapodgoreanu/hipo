{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Duckle: debug backend",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}\\target\\debug\\duckle.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "environment": [
        { "name": "DUCKLE_DUCKDB_BIN", "value": "${workspaceFolder}\\.duckdb-cli-v1.5.3\\duckdb.exe" },
        { "name": "RUST_BACKTRACE", "value": "1" },
        { "name": "RUST_LOG", "value": "info" }
      ],
      "preLaunchTask": "tauri: build desktop debug",
      "dependsOn": "tauri: frontend dev server",
      "dependsOrder": "parallel",
      "stopAtEntry": false,
      "console": "integratedTerminal"
    }
  ]
}
